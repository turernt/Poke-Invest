# ── Supabase (obligatoire) ────────────────────────────────────────────────────
# Trouvez ces valeurs dans : https://supabase.com/dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── eBay Browse API (optionnel) ───────────────────────────────────────────────
# Sans ce token, le bouton eBay ouvre une recherche eBay dans un nouvel onglet.
# Générez un token OAuth eBay : https://developer.ebay.com/my/keys
EBAY_OAUTH_TOKEN=v^1.1#i^1#r^0#f^0#p^3#I^3#t^...

# ── Tests E2E Playwright (dev uniquement) ─────────────────────────────────────
# Compte de test dédié — ne jamais utiliser un compte réel ici
E2E_EMAIL=test@exemple.com
E2E_PASSWORD=MotDePasseTest123!
